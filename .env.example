# ytdl4me configuration — every variable is optional.
# Copy to .env and uncomment what you need. docker-compose picks up .env automatically.

# Port the server listens on (the Docker image always listens on 8000 internally).
#PORT=8000

# If set, every /api/* route (except /api/health) requires this key,
# sent as the "X-Access-Key" header or a "?key=" query parameter.
# Strongly recommended for any internet-facing deployment.
#ACCESS_KEY=change-me-to-something-long-and-random

# Working directory for job files; each job gets its own subdirectory.
# Default: <repo>/downloads locally, /data inside the Docker image.
#DOWNLOAD_DIR=/data

# Completed job files older than this many minutes are deleted by a
# background cleanup task (runs every 5 minutes).
#FILE_TTL_MINUTES=60

# Maximum simultaneous downloads; extra jobs wait in the queue.
#MAX_CONCURRENT_JOBS=3

# Cap on non-terminal jobs before /api/download returns 429 (flood guard).
# Defaults to MAX_CONCURRENT_JOBS * 4.
#MAX_ACTIVE_JOBS=12

# Per-IP sliding-window limit (per minute) on /api/probe and /api/download.
# 0 disables it.
#RATE_LIMIT_PER_MINUTE=30

# By default only YouTube, Vimeo, SoundCloud, and Spotify URLs are accepted.
# Set to true to allow any site yt-dlp supports (not recommended when exposed).
#ALLOW_ANY_SITE=false

# Spotify API credentials. Reserved for future album/playlist enumeration;
# unused in v1 (single tracks resolve via public metadata, no credentials needed).
#SPOTIFY_CLIENT_ID=
#SPOTIFY_CLIENT_SECRET=

# Browser cookies passed to yt-dlp. Needed when YouTube answers with
# "Sign in to confirm you're not a bot" — common from cloud/datacenter IPs
# (Railway, Fly, etc.). See the README "YouTube bot check" section.
# Provide ONE of the following:
#   COOKIES_FILE     — path to a Netscape cookies.txt (best when you can mount a file)
#   COOKIES_B64      — base64 of a cookies.txt (best for Railway/Fly env vars)
#   COOKIES_CONTENT  — raw cookies.txt contents (multiline)
#COOKIES_FILE=/data/cookies.txt
#COOKIES_B64=
#COOKIES_CONTENT=

# Self-renewing cookies: point this at a path on a PERSISTENT volume. The file
# is seeded once from COOKIES_B64/COOKIES_CONTENT/COOKIES_FILE, then yt-dlp's
# rotated cookies are written back after each run so the YouTube session keeps
# renewing itself instead of going stale. Needs a real volume to survive
# restarts (e.g. a Railway volume mounted at /state).
#COOKIES_STATE_FILE=/state/cookies.txt

# Widevine L3 device (.wvd) for SoundCloud DRM tracks (ctr-encrypted-hls).
# Optional: if unset, the server caches a public L3 device on first DRM download.
# Provide ONE of:
#   WIDEVINE_DEVICE_FILE  — path to a pywidevine .wvd
#   WIDEVINE_DEVICE_B64   — base64 of a .wvd (Railway/Fly-friendly)
#WIDEVINE_DEVICE_FILE=
#WIDEVINE_DEVICE_B64=
